package System;

import Float128;

internal SinImpl: (x: f128) -> f128
{
    let exp := BiasedExponent(x);

    // sin(NaN) = NaN; sin(inf) = NaN
    if exp == MaxBiasedExponent {
        return f128.NaN;
    }

    if x.Abs < PI_4 {
        if exp < 0x3fff - (113 \ 2) {
            return x;
        }

        return SinInternal(x, 0, 0);
    }

    high, low: f128;
    let n := RemPIO2(x, &high, &low) & 3;

    return switch n {
        0 => SinInternal(high, low, 1),
        1 => CosInternal(high, low),
        2 => -SinInternal(high, low, 1),
        _ => -CosInternal(high, low)
    };
}

internal CosImpl: (x: f128) -> f128
{
    let exp := BiasedExponent(x);

    // cos(NaN) = NaN; cos(inf) = NaN
    if exp == MaxBiasedExponent {
        return f128.NaN;
    }

    if x.Abs < PI_4 {
        if exp < 0x3fff - (113 \ 2) {
            return x + 1;
        }

        return CosInternal(x, 0);
    }

    high, low: f128;
    let n := RemPIO2(x, &high, &low) & 3;

    return switch n {
        0 => CosInternal(high, low),
        1 => -SinInternal(high, low, 1),
        2 => -CosInternal(high, low),
        _ => SinInternal(high, low, 1)
    };
}

internal SinCosImpl: (x: f128) -> (f128, f128)
{
    let exp := BiasedExponent(x);

    // sin/cos(NaN) = NaN; sin/cos(inf) = NaN
    if exp == MaxBiasedExponent {
        return (f128.NaN, f128.NaN);
    }

    if x.Abs < PI_4 {
        if exp < 0x3fff - (113 \ 2) {
            return (x, x + 1);
        }

        return (SinInternal(x, 0, 0), CosInternal(x, 0));
    }

    high, low: f128;
    let n := RemPIO2(x, &high, &low) & 3;
    let sin := SinInternal(high, low, 1);
    let cos := CosInternal(high, low);

    return switch n {
        0 => (sin, cos),
        1 => (cos, -sin),
        2 => (-sin, -cos),
        _ => (-cos, sin)
    };
}

internal TanImpl: (x: f128) -> f128
{
    ix := x.Bits.High64() & 0x7fffffffffffffffu64;
    if ix <= 0x3ffe921fb54442d1u64 {
        return TanInternal(x, 0, 1);
    } else if ix >= 0x7fff000000000000u64 {
        return f128.NaN;
    } else {
        high, low: f128;
        let n := RemPIO2(x, &high, &low);
        return TanInternal(high, low, 1 - ((n & 1) << 1));
    }
}

internal AsinImpl: (x: f128) -> f128
{
    let exp := BiasedExponent(x);
    let sign := x.IsNegative;

    // |x| >= 1 or nan
    if exp >= 0x3FFFu {
        if x == f128.One or x == f128.MinusOne {
            return x * PIO2_HI + f128.FromBits(0x3F87_0000_0000_0000_0000_0000_0000_0000_u128);
        }

        return f128.NaN;
    }

    // |x| < 0.5
    if exp < 0x3FFF - 1 {
        if exp < 0x3FFF - (114 \ 2) {
            return x;
        }

        return x + x * R(x * x);
    }

    // 1 > |x| >= 0.5
    let z := (f128.One - x.Abs) * f128(0.5);
    let s := z.Sqrt;
    let r := R(z);
    if ((x.Bits.High64() >> 32) & 0xFFFFu) >= 0xEE00 {
        x = PIO2_HI - (f128(2) * (s + s * r) - PIO2_LO);
    } else {
        let f := f128.FromBits(u128(s.Bits.High64(), 0u));
        let c := (z - f * f) / (s + f);
        x = f128(0.5) * PIO2_HI - (f128(2) * s * r - (PIO2_LO - c * 2) - (f128(0.5) * PIO2_HI - f * 2));
    }

    return sign ? -x : x;
}

internal AcosImpl: (x: f128) -> f128
{
    if x == 0 {
        return PI_2;
    }

    if x >= f128.One {
        if x == f128.One {
            return 0;
        }
        return f128.NaN;
    }

    if x <= f128.MinusOne {
        if x == f128.MinusOne {
            return f128.Pi;
        }
        return f128.NaN;
    }

    let y := ((f128.One - (x * x)).Sqrt / x).Atan;
    return x > 0 ? y : y + f128.Pi;
}

internal AtanImpl: (x: f128) -> f128
{
    let exp := BiasedExponent(x);
    let sign := x.IsNegative;

    if exp >= 0x3FFF + 114 {
        if x.IsNaN {
            return x;
        }
        return sign ? -(AtanHi[3]) : AtanHi[3];
    }

    let expman := (u32(exp) << 8) | (x.Bits.High64() >> 40).NarrowToUInt8();
    id: i32;
    // |x| < 0.4375
    if expman < ((0x3FFF - 2) << 8) + 0xC0 {
        if exp < 0x3FFF - (114 \ 2) {
            if x.IsSubnormal {
                x = f128.NegativeInfinity;
            }
            return x;
        }
        id = -1;
    } else {
        x = x.Abs;
        if expman < (0x3fff << 8) + 0x30 {
            // |x| < 1.1875
            if expman < ((0x3fff - 1) << 8) + 0x60 {
                id = 0;
                x = (f128(2) * x - f128.One) / (f128(2) + x);
            } else {
                id = 1;
                x = (x - f128.One) / (x + f128.One);
            }
        } else {
            if expman < ((0x3fff + 1) << 8) + 0x38 {
                id = 2;
                const oneHalf :== f128.FromBits(0x3FFF_8000_0000_0000_0000_0000_0000_0000_u128);
                x = (x - oneHalf) / (f128.One + oneHalf * x);
            } else {
                id = 3;
                x = f128.MinusOne / x;
            }
        }
    }

    z := x * x;
    let w := z * z;
    let s1 := z * Even(w);
    let s2 := w * Odd(w);
    if id < 0 {
        return x - x * (s1 + s2);
    }
    z = AtanHi[id] - ((x * (s1 + s2) - AtanLo[id]) - x);
    return sign ? -z : z;
}

internal Atan2Impl: (y: f128, x: f128) -> f128
{
    if x.IsNaN or y.IsNaN {
        return f128.NaN;
    }

    let ex: i32 = BiasedExponent(x);
    let ey: i32 = BiasedExponent(y);
    let m := i32(2 * (x.Bits.High64() >> 63) | (y.Bits.High64() >> 63));

    if y == 0 {
        return switch m {
            0 or 1 => y,
            2 => f128(2) * PIO2_HI,
            3 => f128(-2) * PIO2_HI
        };
    }
    if x == 0 {
        return ((m & 1) != 0) ? -PIO2_HI : PIO2_HI;
    }
    if ex == MaxBiasedExponent {
        if ey == MaxBiasedExponent {
            const oneHalf :== f128.FromBits(0x3FFF_8000_0000_0000_0000_0000_0000_0000_u128);

            return switch m {
                0 => PIO2_HI / 2,
                1 => -PIO2_HI / 2,
                2 => oneHalf * PIO2_HI,
                3 => -oneHalf * PIO2_HI
            };
        } else {
            return switch m {
                0 => 0.0f128,
                1 => f128.NegativeZero,
                2 => f128(2) * PIO2_HI,
                3 => f128(-2) * PIO2_HI
            };
        }
    }

    if ex + 120 < ey or ey == MaxBiasedExponent {
        return ((m & 1) != 0) ? -PIO2_HI : PIO2_HI;
    }

    z: f128;
    if ((m & 2) != 0) and ey + 120 < ex {
        z = 0;
    } else {
        z = ((y / x).Abs).Atan;
    }

    return switch m {
        0 => z,
        1 => -z,
        2 => f128(2) * PIO2_HI - (z - f128(2) * PIO2_LO),
        _ => (z - f128(2) * PIO2_LO) - f128(2) * PIO2_HI
    };
}

internal SinPiImpl: (x: f128) -> f128
{
    const PiHi :== f128.FromBits(0x4000_921F_B544_42D1_8400_0000_0000_0000_u128);
    const PiLo :== f128.FromBits(0x3FC6_A626_3314_5C06_E0E6_8948_1270_4453_u128);

    let ax := x.Abs;
    hi, lo, s: f128;

    if ax < f128.One {
        if ax < Quarter {
            if ax < f128.FromBits(0x3FC3_0000_0000_0000_0000_0000_0000_0000_u128) {
                if x == 0 {
                    return x;
                }

                hi = x.ToFloat64();
                hi *= f128.FromBits(0x4070_0000_0000_0000_0000_0000_0000_0000_u128);
                lo = x * f128.FromBits(0x4070_0000_0000_0000_0000_0000_0000_0000_u128) - hi;
                s = (PiLo + PiHi) * lo + PiLo * lo + PiHi * hi;
                return s * f128.FromBits(0x3F8E_0000_0000_0000_0000_0000_0000_0000_u128);
            }

            s = SinPiInternal(ax);
            return x < 0 ? -s : s;
        }

        if ax < HalfOne {
            s = CosPiInternal(HalfOne - ax);
        } else if ax < ThreeFourth {
            s = CosPiInternal(ax - HalfOne);
        } else {
            s = SinPiInternal(f128.One - ax);
        }

        return x < 0 ? -s : s;
    }

    if ax < f128.FromBits(0x406F_0000_0000_0000_0000_0000_0000_0000_u128) {
        let ai, ar := FastFloor(ax);

        if ar == 0 {
            s = 0;
        } else {
            if ar < HalfOne {
                if ar <= Quarter {
                    s = SinPiInternal(ar);
                } else {
                    s = CosPiInternal(HalfOne - ar);
                }
            } else {
                if ar < ThreeFourth {
                    s = CosPiInternal(ar - HalfOne);
                } else {
                    s = SinPiInternal(f128.One - ar);
                }
            }

            s = ai.IsEvenInteger ? s : -s;
        }

        return x < 0 ? -s : s;
    }

    if x.IsNaN or x.IsInfinity {
        return f128.NaN;
    }

    return f128.Zero.CopySign(x);
}

internal CosPiImpl: (x: f128) -> f128
{
    let ax := x.Abs;
    c: f128;

    if ax <= f128.One {
        if ax < Quarter {
            if ax < f128.FromBits(0x3FC3_0000_0000_0000_0000_0000_0000_0000_u128) {
                if x.NarrowToInt32() == 0 {
                    return f128.One;
                }
            }

            return CosPiInternal(ax);
        }

        if ax < HalfOne {
            c = SinPiInternal(HalfOne - ax);
        } else if ax < ThreeFourth {
            if ax == HalfOne {
                return 0;
            }
            c = -SinPiInternal(ax - HalfOne);
        } else {
            c = -CosPiInternal(f128.One - ax);
        }

        return c;
    }

    if ax < f128.FromBits(0x406F_0000_0000_0000_0000_0000_0000_0000_u128) {
        let ai, ar := FastFloor(ax);

        if ar < HalfOne {
            if ar < Quarter {
                c = ar == 0 ? f128.One : CosPiInternal(ar);
            } else {
                c = SinPiInternal(HalfOne - ar);
            }
        } else {
            if ar < ThreeFourth {
                if ar == HalfOne {
                    return 0;
                }
                c = -SinPiInternal(ar - HalfOne);
            } else {
                c = -CosPiInternal(f128.One - ar);
            }
        }

        return ai.IsEvenInteger ? c : -c;
    }

    if x.IsNaN or x.IsInfinity {
        return f128.NaN;
    }

    if ax >= f128.FromBits(0x4070_0000_0000_0000_0000_0000_0000_0000_u128) {
        return f128.One;
    }

    return ax.IsEvenInteger ? f128.One : f128.MinusOne;
}

internal TanPiImpl: (x: f128) -> f128
{
    const PiHi :== f128.FromBits(0x4000_921F_B544_42D1_8400_0000_0000_0000_u128);
    const PiLo :== f128.FromBits(0x3FC6_A626_3314_5C06_E0E6_8948_1270_4453_u128);

    let ax := x.Abs;
    hi, lo, t: f128;

    if ax < f128.One {
        if ax < HalfOne {
            if ax < f128.FromBits(0x3FC3_0000_0000_0000_0000_0000_0000_0000_u128) {
                if x == 0 {
                    return x;
                }

                hi = x.ToFloat64();
                hi *= f128.FromBits(0x4070_0000_0000_0000_0000_0000_0000_0000_u128);
                lo = x * f128.FromBits(0x4070_0000_0000_0000_0000_0000_0000_0000_u128) - hi;
                t = (PiLo + PiHi) * lo + PiLo * lo + PiHi * hi;
                return t * f128.FromBits(0x3F8E_0000_0000_0000_0000_0000_0000_0000_u128);
            }

            t = TanPiInternal(ax);
        } else if ax == HalfOne {
            t = f128.PositiveInfinity;
        } else {
            t = -TanPiInternal(f128.One - ax);
        }

        return x < 0 ? -t : t;
    }

    if ax < f128.FromBits(0x406F_0000_0000_0000_0000_0000_0000_0000_u128) {
        let ai, ar := FastFloor(ax);
        let odd := ai.IsEvenInteger ? f128.One : f128.MinusOne;
        
        if ar < HalfOne {
            t = ar == 0 ? f128.Zero.CopySign(odd) : TanPiInternal(ar);
        } else if ar == HalfOne {
            t = odd / f128.Zero;
        } else {
            t = -TanPiInternal(f128.One - ar);
        }

        return x < 0 ? -t : t;
    }

    if x.IsNaN or x.IsInfinity {
        return f128.NaN;
    }

    t = ax.IsEvenInteger ? f128.Zero : f128.NegativeZero;
    return t.CopySign(x);
}

private {
    const SignMask :== 0x8000_0000_0000_0000_0000_0000_0000_0000_u128;
    const SignShift :== 127i32;
    const ShiftedSignMask: u8 == u8(SignMask >> SignShift);

    const BiasedExponentMask :== 0x7FFF_0000_0000_0000_0000_0000_0000_0000_u128;
    const BiasedExponentShift :== 112i32;
    const ShiftedBiasedExponentMask: u16 == u16(BiasedExponentMask >> BiasedExponentShift);

    const TrailingSignificandMask :== 0x0000_FFFF_FFFF_FFFF_FFFF_FFFF_FFFF_FFFF_u128;

    const MinSign :== 0u8;
    const MaxSign :== 1u8;
    const MinBiasedExponent :== u16.MinValue;
    const MaxBiasedExponent :== 0x7FFFu16;
    const ExpBias :== 16383u16;
    const MinExponent :== -16382i16;
    const MaxExponent :== +16383i16;
    const MinTrailingSignificand :== u128.MinValue;
    const MaxTrailingSignificand :== 0x0000_FFFF_FFFF_FFFF_FFFF_FFFF_FFFF_FFFF_u128;

    const TrailingSignificandLength :== 112;
    const SignificandLength :== TrailingSignificandLength + 1;

    const RoundingEpsilon :== Builtin.BitCast<f128>(0x406F_0000_0000_0000_0000_0000_0000_0000_u128);

    BiasedExponent: (value: f128) -> u16 noexcept ==> ExtractBiasedExponentFromBits(value.Bits);
    Exponent: (value: f128) -> i16 noexcept ==> i16(BiasedExponent(value) - ExpBias);
    Significand: (value: f128) -> u128 noexcept ==> TrailingSignificand(value) | (BiasedExponent(value) != 0 ? (1u128 << BiasedExponentShift) : 0u128);
    TrailingSignificand: (value: f128) -> u128 noexcept ==> ExtractTrailingSignificandFromBits(value.Bits);

    ExtractBiasedExponentFromBits: (bits: u128) -> u16 noexcept ==> u16((bits >> BiasedExponentShift) & ShiftedBiasedExponentMask);
    ExtractTrailingSignificandFromBits: (bits: u128) -> u128 noexcept ==> bits & TrailingSignificandMask;
}

// Asin helper constants

private const pS0 :== f128.FromBits(0x3FFC_5555_5555_5555_5555_5555_5555_5ACB_u128);
private const pS1 :== f128.FromBits(0xBFFE_7733_C865_9C3C_29EA_3614_B02F_2E41_u128);
private const pS2 :== f128.FromBits(0x3FFF_5797_9B5B_674E_91B5_0237_574C_7D1E_u128);
private const pS3 :== f128.FromBits(0xBFFF_5328_2885_3E02_7A76_AE0D_EC75_A3DC_u128);
private const pS4 :== f128.FromBits(0x3FFE_85BC_D120_445D_1E68_6012_F127_DCD9_u128);
private const pS5 :== f128.FromBits(0xBFFD_0650_52B7_026F_590C_744B_6978_9B90_u128);
private const pS6 :== f128.FromBits(0x3FFA_89CD_FE96_9597_D61A_8F51_A8DD_0C37_u128);
private const pS7 :== f128.FromBits(0xBFF7_2203_159A_1D9D_9944_1478_415C_791C_u128);
private const pS8 :== f128.FromBits(0x3FF2_2F25_83B7_EC31_8DDA_1ADA_B639_2121_u128);
private const pS9 :== f128.FromBits(0xBFE8_C42C_02E3_4D40_972F_241C_19F8_A186_u128);
private const qS1 :== f128.FromBits(0xC001_3633_A319_01F9_EC3C_755C_50ED_E994_u128);
private const qS2 :== f128.FromBits(0x4002_3EEB_09AC_020A_0443_12EC_E6E7_A13E_u128);
private const qS3 :== f128.FromBits(0xC002_6A2B_54F9_B826_9216_B712_3B22_1EAB_u128);
private const qS4 :== f128.FromBits(0x4001_EF5C_E06F_68D3_B151_4081_08B0_3471_u128);
private const qS5 :== f128.FromBits(0xC000_A11D_BB7D_E998_9DDC_9D89_0C3A_63C4_u128);
private const qS6 :== f128.FromBits(0x3FFE_A7D9_6024_76DB_8849_72B3_5236_11EE_u128);
private const qS7 :== f128.FromBits(0xBFFB_E679_5462_B32C_A615_34B1_42EE_9992_u128);
private const qS8 :== f128.FromBits(0x3FF8_10D3_9D46_3279_7749_8241_5549_DFE3_u128);
private const qS9 :== f128.FromBits(0xBFF2_A230_064A_F874_87AA_66DC_CC58_B501_u128);

private inline R: (z: f128) -> f128 noexcept ==
{
    let p := z * (pS0 + z * (pS1 + z * (pS2 + z * (pS3 + z * (pS4 + z * (pS5 + z * (pS6 + z * (pS7 + z * (pS8 + z * pS9)))))))));
    let q := f128.One + z * (qS1 + z * (qS2 + z * (qS3 + z * (qS4 + z * (qS5 + z * (qS6 + z * (qS7 + z * (qS8 + z * qS9))))))));
    return p / q;
}

// Atan helper constants

private Even: (x: f128) -> f128 noexcept ==
{
    let x0 := (AT[20] + x * AT[22]);
    let x1 := (AT[18] + x * x0);
    let x2 := (AT[16] + x * x1);
    let x3 := (AT[14] + x * x2);
    let x4 := (AT[12] + x * x3);
    let x5 := (AT[10] + x * x4);
    let x6 := (AT[8] + x * x5);
    let x7 := (AT[6] + x * x6);
    let x8 := (AT[4] + x * x7);
    let x9 := (AT[2] + x * x8);
    return (AT[0] + x * x9);
}

private Odd: (x: f128) -> f128 noexcept ==
{
    let x0 := (AT[21] + x * AT[23]);
    let x1 := (AT[19] + x * x0);
    let x2 := (AT[17] + x * x1);
    let x3 := (AT[15] + x * x2);
    let x4 := (AT[13] + x * x3);
    let x5 := (AT[11] + x * x4);
    let x6 := (AT[9] + x * x5);
    let x7 := (AT[7] + x * x6);
    let x8 := (AT[5] + x * x7);
    let x9 := (AT[3] + x * x8);
    return (AT[1] + x * x9);
}

// Cos helper constants

private const C1  :== f128.FromBits(0x3FFA_5555_5555_5555_5555_5555_5555_5548_u128);
private const C2  :== f128.FromBits(0xBFF5_6C16_C16C_16C1_6C16_C16C_16BF_5C98_u128);
private const C3  :== f128.FromBits(0x3FEF_A01A_01A0_1A01_A01A_019F_FFC4_B13D_u128);
private const C4  :== f128.FromBits(0xBFE9_27E4_FB77_89F5_C72E_EF94_869C_AC2A_u128);
private const C5  :== f128.FromBits(0x3FE2_1EED_8EFF_8D89_7B51_B5F6_2EA9_599A_u128);
private const C6  :== f128.FromBits(0xBFDA_9397_4A8C_07C9_C2A3_8FC4_4BBC_8DF5_u128);
private const C7  :== f128.FromBits(0x3FD2_AE7F_3E73_3B48_DDA7_3725_A8CB_76C2_u128);
private const C8  :== f128.FromBits(0xBFCA_6827_863B_100E_C1D2_05BD_6344_4584_u128);
private const C9  :== f128.FromBits(0x3FC1_E542_B8A1_08C0_71EB_27E7_68BA_79E3_u128);
private const C10 :== f128.FromBits(0xBFB9_0CE2_0CD8_68A2_04B8_FF44_E6BF_56E0_u128);
private const C11 :== f128.FromBits(0x3FAF_EF81_27D7_65B0_90B7_B2A6_9D9B_4DA3_u128);

private Poly: (z: f128) -> f128 noexcept ==
{
    let r := (z * (C1 + z * (C2 + z * (C3 + z * (C4 + z * (C5 + z * (C6 + z * 
        (C7 + z * (C8 + z * (C9 + z * (C10 + z * C11)))))))))));
    return r;
}

// Sin helper constants

private const S1  :== f128.FromBits(0xBFFC_5555_5555_5555_5555_5555_5555_5555_u128);
private const S2  :== f128.FromBits(0x3FF8_1111_1111_1111_1111_1111_1111_107F_u128);
private const S3  :== f128.FromBits(0xBFF2_A01A_01A0_1A01_A01A_01A0_19F8_F785_u128);
private const S4  :== f128.FromBits(0x3FEC_71DE_3A55_6C73_38FA_AC1C_5571_67FE_u128);
private const S5  :== f128.FromBits(0xBFE5_AE64_567F_544E_38FE_7342_6974_AE93_u128);
private const S6  :== f128.FromBits(0x3FDE_6124_613A_86D0_97C5_C00C_FA3D_6509_u128);
private const S7  :== f128.FromBits(0xBFD6_AE7F_3E73_3B81_DC97_972A_DED6_8D8D_u128);
private const S8  :== f128.FromBits(0x3FCE_952C_7703_0A96_9D8A_B423_F5C4_7870_u128);
private const S9  :== f128.FromBits(0xBFC6_2F49_B467_96FE_3000_0000_0000_0000_u128);
private const S10 :== f128.FromBits(0x3FBD_71B8_EE20_94BA_E000_0000_0000_0000_u128);
private const S11 :== f128.FromBits(0xBFB4_7619_0E26_27FC_D000_0000_0000_0000_u128);
private const S12 :== f128.FromBits(0x3FAB_3D19_FFD7_AD8B_F000_0000_0000_0000_u128);

