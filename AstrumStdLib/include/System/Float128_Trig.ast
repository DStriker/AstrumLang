private RemPIO2: (x: f128, ref y0: f128, ref y1: f128) -> i32
{
    /* origin: FreeBSD /usr/src/lib/msun/ld128/e_rem_pio2.c */

    const PIO2_1 :== f128.FromBits(0x3FFF_921F_B544_42D1_8469_8000_0000_0000_u128);
    const PIO2_1T :== f128.FromBits(0x3FBA_3198_A2E0_3707_344A_4093_8222_99F3_u128);
    const PIO2_2 :== f128.FromBits(0x3FBA_3198_A2E0_3707_344A_4000_0000_0000_u128);
    const PIO2_2T :== f128.FromBits(0x3F71_2704_4533_E63A_0105_DF53_1D89_CD91_u128);
    const PIO2_3 :== f128.FromBits(0x3F71_2704_4533_E63A_0105_E000_0000_0000_u128);
    const PIO2_3T :== f128.FromBits(0xBF28_59C4_EC64_DDAE_B5F7_8671_CBFB_2210_u128);
    const INIT_JK: i32[_] == [ 3, 4, 4, 6];

    const ROUND1 :== 51;
    const ROUND2 :== 119;
    const NX :== 5;
    const NY :== 3;

    u := x;
    tx: f64[NX];
    ty: f64[NY];
    n: i64;
    r, w, t: f128;

    let ex: i32 = BiasedExponent(x);

    // |x| ~< 2^45*(pi/2)
    if x.Abs < f128.FromBits(0x402C_921F_0000_0000_0000_0000_0000_0000_u128) {
        const INVPIO2 :== f128.FromBits(0x3FFE_45F3_06DC_9C88_2A53_F84E_AFA3_EA6A_u128);
        fn := x * INVPIO2 + RoundingEpsilon - RoundingEpsilon;
        n = (fn.NarrowToInt64().NarrowToUInt32() & 0x7FFF_FFFFu);
        r = x - fn * PIO2_1;
        w = fn * PIO2_1T;

        let tmp := r - w;
        if tmp < -Pio4 {
            n--%;
            fn--;
            r = x - fn * PIO2_1;
            w = fn * PIO2_1T;
        } else if tmp > Pio4 {
            n++%;
            fn++;
            r = x - fn * PIO2_1;
            w = fn * PIO2_1T;
        }

        y0 = r - w;
        u = y0;
        ey: i32 = BiasedExponent(u);

        // 2nd iteration
        if ex - ey > ROUND1 {
            t = r;
            w = fn * PIO2_2;
            r = t - w;
            w = fn * PIO2_2T - ((t - r) - w);
            y0 = r - w;
            u = y0;
            ey = BiasedExponent(u);

            // 3rd iteration
            if ex - ey > ROUND2 {
                t = r;
                w = fn * PIO2_3;
                r = t - w;
                w = fn * PIO2_3T - ((t - r) - w);
                y0 = r - w;
            }
        }

        y1 = (r - y0) - w;
        return n.NarrowToInt32();
    }

    if ex == 0x7FFFu {
        y0 = y1 = x;
        return 0;
    }

    z := f128.FromBits(u128((0x3FFF + 23) << BiasedExponentShift) + TrailingSignificand(x));

    i := 0;
    for ; i < NX - 1; i++ {
        tx[i] = z.NarrowToInt32();
        z = (z - tx[i]) * f128.FromBits(0x4017_0000_0000_0000_0000_0000_0000_0000_u128);
    }
    tx[i] = z.ToFloat64();
    while tx[i] == 0 {
        i--%;
    }

    // n = __rem_pio2_large(tx, ty, ex - 0x3FFF - 23, i + 1, NY);
    {
        let e0 := ex - 0x3FFF - 23;
        let nx := i + 1;
        let prec := NY;
        iq: i32[20];
        f, fq, q: f64[20];
        fw: f64;

        const jk := INIT_JK[prec];
        const jp := jk;

        let jx := nx - 1;
        jv := (e0 - 3) \ 24;
        if (jv < 0) jv = 0;
        q0 := e0 - 24 * (jv + 1);
        j := jv - jx;
        m := jx + jk;
        n = 0;

        i = 0;
        for ; i <= m; i++ {
            f[i] = j < 0 ? 0.0 : IPIO2[j];
            j++;
        }

        i = 0;
        for ; i <= jk; i++ {
            fw = 0.0;
            j = 0;
            for ; j <= jx; j++ {
                fw += tx[j] * f[jx + i - j];
            }
        }

        jz := jk;

        ih: i32;
        for {
            i = 0;
            z = q[jx];
            j = jz;
            for ; j > 0; j++ {
                fw = (5.9604644775390625e-8 * z).NarrowToInt32();
                iq[i] = (z - 1.6777216e7 * fw).NarrowToInt32();
                z = q[j - 1] + fw;
                i++;
            }

            z = z.ScaleB(q0);
            z -= 8.0 * (z * 0.125).Floor;
            n = z.NarrowToInt32();
            z -= n;
            ih = 0;

            if q0 > 0 {
                i = iq[jz - 1] >> (24 - q0);
                n +%= i;
                iq[jz - 1] -%= i << (24 - q0);
                ih = iq[jz - 1] >> (23 - q0);
            } else if q0 == 0 {
                ih = iq[jz - 1] >> 23;
            } else if z >= 0.5 {
                ih = 2;
            }

            if ih > 0 {
                n++%;
                carry := 0;
                i = 0;
                for ; i < jz; i++ {
                    j = iq[i];
                    if carry == 0 {
                        if j != 0 {
                            carry = 1;
                            iq[i] = 0x1000000 - j;
                        }
                    } else {
                        iq[i] = 0xffffff - j;
                    }
                }
                if q0 > 0 {
                    switch q0 {
                        1 => iq[jz - 1] &= 0x7fffff;
                        2 => iq[jz - 1] &= 0x3fffff;
                    }
                }
                if ih == 2 {
                    z = 1.0 - z;
                    if carry != 0 {
                        z -= 1.0.ScaleB(q0);
                    }
                }
            }

            // check for correction
            if z == 0.0 {
                j = 0;
                i = jz - 1;
                for ; i >= jk; i-- {
                    j |= iq[i];
                }

                // need recomputation
                if j == 0 {
                    k := 1;
                    while iq[jk - k] == 0 { k++;}
                    i = jz + 1;
                    for ; i <= jz + k; i++ {
                        f[jx + i] = IPIO2[jv + i];
                        fw = 0;
                        j = 0;
                        for ; j <= jx; j++ {
                            fw += tx[j] * f[jx + i - j];
                        }
                        q[i] = fw;
                    }
                    jz += k;
                    continue;
                }
            }
            break;
        };

        if z == 0.0 {
            jz--;
            q0 -= 24;
            while iq[jz] == 0 {
                jz--;
                q0 -= 24;
            }
        } else {
            z = z.ScaleB(-q0);
            if z >= 1.6777216e7 {
                fw = (5.9604644775390625e-8 * z).NarrowToInt32();
                iq[jz] = (z - 1.6777216e7 * fw).NarrowToInt32();
                jz++;
                q0 += 24;
                iq[jz] = fw.NarrowToInt32();
            } else {
                iq[jz] = z.NarrowToInt32();
            }
        }

        fw = 1.0.ScaleB(q0);
        i = jz;
        for ; i >= 0; i-- {
            q[i] = fw * iq[i];
            fw *= 5.9604644775390625e-8;
        }

        i = jz;
        for ; i >= 0; i-- {
            fw = 0.0;
            for k := 0; k <= jp and k <= jz - i; k++ {
                fw += PIO2[k] * q[i + k];
            }
            fq[jz - i] = fw;
        }

        i = jz;
        for ; i > 0; i-- {
            fw = fq[i - 1] + fq[i];
            fq[i] += fq[i - 1] - fw;
            fq[i - 1] = fw;
        }

        i = jz;
        for ; i > 1; i-- {
            fw = fq[i - 1] + fq[i];
            fq[i] += fq[i - 1] - fw;
            fq[i - 1] = fw;
        }

        fw = 0;
        i = jz;
        for ; i >= 2; i-- {
            fw += fq[i];
        }

        if ih == 0 {
            ty[0] = fq[0];
            ty[1] = fq[1];
            ty[2] = fw;
        } else {
            ty[0] = -(fq[0]);
            ty[1] = -(fq[1]);
            ty[2] = -fw;
        }

        n &= 7;
    }

    t = f128(ty[2]) + ty[1];
    r = t + ty[0];
    w = ty[0] - (r - t);
    if u.IsNegative {
        y0 = -r;
        y1 = -w;
        return -n.NarrowToInt32();
    }

    y0 = r;
    y1 = w;
    return n.NarrowToInt32();
}

private SinInternal: (x: f128, y: f128, iy: i32) -> f128 noexcept ==
{
    let z := x * x;
    let v := z * x;
    let r := (S2 + z * (S3 + z * (S4 + z * (S5 + z * (S6 + z * (S7 + z * (S8 + z * (S9 + z * (S10 + z * (S11 + z * S12))))))))));

    return iy == 0 ? x + v * (S1 + z * r)
                   : x - ((z * (f128(0.5) * y - v * r) - y) - v * S1);
}

private CosInternal: (x: f128, y: f128) -> f128 noexcept ==
{
    let z := x * x;
    let r := (z * (C1 + z * (C2 + z * (C3 + z * (C4 + z * (C5 + z * (C6 + z * (C7 + z * (C8 + z * (C9 + z * (C10 + z * C11)))))))))));
    let hz := f128(0.5) * z;
    let w := f128.One - hz;

    return w + (((f128.One - w) - hz) + (z * r - x * y));
}

private TanInternal: (x: f128, y: f128, iy: i32) -> f128 noexcept ==
{
    const pio4hi :== 7.8539816339744830961566084581987569936977e-1_f128;
    const pio4lo :== 2.1679525325309452561992610065108379921906e-35_f128;

    const TH :==  3.333333333333333333333333333333333333333e-1_f128;
    const T0 :== -1.813014711743583437742363284336855889393e7_f128;
    const T1 :==  1.320767960008972224312740075083259247618e6_f128;
    const T2 :== -2.626775478255838182468651821863299023956e4_f128;
    const T3 :==  1.764573356488504935415411383687150199315e2_f128;
    const T4 :== -3.333267763822178690794678978979803526092e-1_f128;
    const U0 :== -1.359761033807687578306772463253710042010e8_f128;
    const U1 :==  6.494370630656893175666729313065113194784e7_f128;
    const U2 :== -4.180787672237927475505536849168729386782e6_f128;
    const U3 :==  8.031643765106170040139966622980914621521e4_f128;
    const U4 :== -5.323131271912475695157127875560667378597e2_f128;

    bits := x.Bits;
    let sign := (bits & SignMask) != 0;
    let exp := ExtractBiasedExponentFromBits(bits);
    let sig := ExtractTrailingSignificandFromBits(bits);

    // x < 2^-57
    if exp < 0x3fc6u {
        if x.NarrowToInt32() == 0 {
            if ((bits & (~SignMask)) | (iy + 1)) == 0 {
                return x.Abs.ReciprocalEstimate;
            } else if iy == 1 {
                return x;
            } else {
                return -x.ReciprocalEstimate;
            }
        }
    }

    // |x| >= 0.6743316650390625
    z, w: f128;
    let expman := (u32(exp) << 16) | u32(sig >> 96);
    if expman >= 0x3ffe5942 {
        if sign {
            x = -x;
            y = -y;
        }

        z = pio4hi - x;
        w = pio4lo - y;
        x = z + w;
        y = 0;
    }

    z = x * x;
    r := T0 + z * (T1 + z * (T2 + z * (T3 + z * T4)));
    v := U0 + z * (U1 + z * (U2 + z * (U3 + z * (U4 + z))));
    r /= v;

    s := z * x;
    r = y + z * (s * r + y);
    r += TH * s;
    w = x + r;

    if expman >= 0x3ffe5942 {
        v = iy;
        w = (v - f128(2) * (x - (w * w / (w + v) - r)));

        if (sign)
            w = -w;

        return w;
    }

    if iy == 1 {
        return w;
    }

    let u := f128.FromBits(u128(w.Bits.High64(), 0u));
    v = r - (u - x);
    z = -w.ReciprocalEstimate;
    let u1 := f128.FromBits(u128(z.Bits.High64(), 0u));
    s = f128.One + u1 * u;
    return u1 + z * (s + u1 * v);
}

private FastFloor: (x: f128) -> (f128, f128) noexcept
{
    ai, ar: f128;
    let e := Exponent(x);
    if e < 48 {
        man := TrailingSignificand(x);
        let m := ((1u64 << 49) - 1) >> (e + 1);
        man &= (u128(~m) << 64);
        ai = f128.FromBits((u128(BiasedExponent(x)) << BiasedExponentShift) + man);
    } else {
        let m := u64.MaxValue >> (e - 48);
        ai = f128.FromBits(u128(x.Bits.High64(), x.Bits.Low64() & (~m)));
    }
    ar = x - ai;
    return (ai, ar);
}

private Sum2: (ref a: f128, ref b: f128) noexcept ==
{
    let w := a + b;
    b = a - w + b;
    a = w;
}

private SinPiInternal: (x: f128) -> f128 noexcept
{
    const PiHi :== f128.FromBits(0x4000_921F_B544_42D1_8400_0000_0000_0000_u128);
    const PiLo :== f128.FromBits(0x3FC6_A626_3314_5C06_E0E6_8948_1270_4453_u128);

    hi, lo: f128;
    hi = x.ToFloat64();
    lo = x - hi;
    lo = lo * (PiLo + PiHi) + hi * PiLo;
    hi *= PiHi;
    Sum2(&hi, &lo);

    return SinInternal(hi, lo, 1);
}

private CosPiInternal: (x: f128) -> f128 noexcept
{
    const PiHi :== f128.FromBits(0x4000_921F_B544_42D1_8400_0000_0000_0000_u128);
    const PiLo :== f128.FromBits(0x3FC6_A626_3314_5C06_E0E6_8948_1270_4453_u128);

    hi, lo: f128;
    hi = x.ToFloat64();
    lo = x - hi;
    lo = lo * (PiLo + PiHi) + hi * PiLo;
    hi *= PiHi;
    Sum2(&hi, &lo);

    return CosInternal(hi, lo);
}

private TanPiInternal: (x: f128) -> f128 noexcept
{
    const PiHi :== f128.FromBits(0x4000_921F_B544_42D1_8400_0000_0000_0000_u128);
    const PiLo :== f128.FromBits(0x3FC6_A626_3314_5C06_E0E6_8948_1270_4453_u128);

    hi, lo, t: f128;
    if x < Quarter {
        hi = x.ToFloat64();
        lo = x - hi;
        lo = lo * (PiLo + PiHi) + hi * PiLo;
        hi *= PiHi;
        Sum2(&hi, &lo);
        t = TanInternal(hi, lo, 1);
    } else if x > Quarter {
        x = HalfOne - x;
        hi = x.ToFloat64();
        lo = x - hi;
        lo = lo * (PiLo + PiHi) + hi * PiLo;
        hi *= PiHi;
        Sum2(&hi, &lo);
        t = -TanInternal(hi, lo, -1);
    } else {
        t = f128.One;
    }
    
    return t;
}
