package System.Numerics;

public interface IIntPowerOperators<TRight, TResult> {
    operator^^: (rhs: TRight) -> TResult;
}

public interface IIntegerPowerArithmetic {
    operator^^: (rhs: u32) -> self;
    operator^^=: (rhs: u32) -> self;
}

public interface ISignedIntegerPowerArithmetic {
    operator^^: (rhs: i32) -> self;
    operator^^=: (rhs: i32) -> self;
}
