package System.Numerics;

public import INumber;
public import IBitwiseOperators;

public interface IBinaryNumber:
    INumber,
    IBitwiseArithmetic
{
    static AllBitsSet: self;

    IsPow2: bool { get; }
    Log2: self { get; }
    Log10: self { get; }

    Log: (base: self) -> self;
    Midpoint: (rhs: self) -> self;
    IsMultipleOf: (rhs: self) -> bool;
}
