private const ExpP6 :== f128.FromBits(0x3FF2_4309_12F8_6C78_76F4_0000_0000_0000_u128);
private const ExpP7 :== 1.52527338040596140779402503651063227608e-05;
private const ExpP8 :== 1.32154867901441125734062539270885494602e-06;
