private const Exp2Table: f128[_] == [
    f128.FromBits(0x3FFE_6A09_E667_F3BC_C908_B2FB_1366_DFEA_u128),
	f128.FromBits(0x3FFE_6C01_2750_BDAB_EED7_6A99_800F_4EDE_u128),
	f128.FromBits(0x3FFE_6DFB_23C6_51A2_EF22_0E2C_BE1B_C0D4_u128),
	f128.FromBits(0x3FFE_6FF7_DF95_1948_3CF8_7E1B_4F3E_1E98_u128),
