private const ExpP10 :== 7.05491279594400222715807284969494195259e-09;
private const ExpRedux :== 60847228810955011271841753858048.0;

private const T1 :== -0.1659;
private const T2 :== 0.1659;
private const T3 :== 0.03125;

private const C3  :== f128.FromBits(0x3FFC_5555_5555_5555_5555_5555_5555_5555_u128);
private const C4  :== f128.FromBits(0x3FFA_5555_5555_5555_5555_5555_5555_5555_u128);
