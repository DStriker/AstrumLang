package System;

import Float128;

internal ExpImpl: (x: f128) -> f128
{
	let e := BiasedExponent(x);

	if e == MaxBiasedExponent {
		if x.IsNaN {
			return f128.NaN;
		}

		return x.IsNegative ? f128.Zero : f128.PositiveInfinity;
	}

	const overflowMark :== 11356.523406294143949491931077970765_f128;
	const underflowMark :== -11433.4627433362978788372438434526231_f128;
	const round96 :== 237684487542793012780631851008.0_f128;
	const round103 :== 30423614405477505635920876929024.0_f128;
	const round111 :== 7788445287802241442795744493830144.0_f128;
	const invLn2 :== 1.44269504088896340735992468100189204_f128;
	const ln2_0 :== 0.693147180559945309417232121457981864_f128;
	const ln2_1 :== -1.94704509238074995158795957333327386e-31_f128;
	const tiny :== 1.0e-4900_f128;
	const two16383 :== 5.94865747678615882542879663314003565e+4931_f128;
	const two8 :== 256.0_f128;
	const two15 :== 32768.0_f128;
	const CP1 :== 0.5_f128;
	const CP2 :== 1.66666666666666666666666666666666683e-1_f128;
	const CP3 :== 4.16666666666666666666654902320001674e-2_f128;
	const CP4 :== 8.33333333333333333333314659767198461e-3_f128;
	const CP5 :== 1.38888888889899438565058018857254025e-3_f128;
	const CP6 :== 1.98412698413981650382436541785404286e-4_f128;

	if x < overflowMark and x > underflowMark {
		const Arg1 :== 2 * 89;
		const Arg2 :== 2 * Arg1 + 2 + 2 * 65;
		const Res1 :== Arg2 + 2 + 2 * 65 + 89;
		const Res2 :== Res1 + 1 + 89 + 65;

		let n := x * invLn2 + round111 - round111;
		let ni := n.NarrowToInt32();
		let isUnsafe := ni.Abs >= 15000;
		x = x - n * ln2_0;
		xl := n * ln2_1;
		t := x + round103 - round103;

		let ti1 := (t * two8).NarrowToInt32();
		x -= ExpTable[Arg1 + 2 * ti1];
		xl -= ExpTable[Arg1 + 2 * ti1 + 1];
		t = x + round96 - round96;

		let ti2 := (t * two15).NarrowToInt32();
		x -= ExpTable[Arg2 + 2 * ti2];
		xl -= ExpTable[Arg2 + 2 * ti2 + 1];

		x += xl;

		u := ExpTable[Res1 + ti1] * ExpTable[Res2 + ti2];
		bits := u.Bits;
		exp := ExtractBiasedExponentFromBits(bits);
		sig := ExtractTrailingSignificandFromBits(bits);
		u = f128.FromBits((bits & SignMask) 
			| ((u128(exp +% (ni >> i32(isUnsafe))) << BiasedExponentShift) & BiasedExponentMask) | sig);
		
		scale := f128.One;
		bits = scale.Bits;
		exp = ExtractBiasedExponentFromBits(bits);
		sig = ExtractTrailingSignificandFromBits(bits);
		scale = f128.FromBits((bits & SignMask) 
			| ((u128(exp +% (ni - (ni >> i32(isUnsafe)))) << BiasedExponentShift) & BiasedExponentMask) | sig);

		let p5 := CP5 + x * CP6;
		let p4 := CP4 + x * p5;
		let p3 := CP3 + x * p4;
		let p2 := CP2 + x * p3;
		let p1 := CP1 + x * p2;
		let x22 := x + x * x * p1;

		result := x22 * u + u;

		if isUnsafe {
			result *= scale;
		}
		return result;
	} else if x < overflowMark {
		return tiny * tiny;
	} else {
		return two16383 * x;
	}
}

internal Exp2Impl: (x: f128) -> f128
{
    let e := BiasedExponent(x);

    // special cases
    // |x| >= 16384 or NaN
    if e >= 0x3FFF + 14 {
        if e >= 0x3FFF + 15 and !x.IsNegative {
            return f128.PositiveInfinity;
        }

        if x.IsNaN {
            return x;
        }

        if e == 0x7FFF {
            return f128.Zero;
        }

        if x < f128.FromBits(0xC00D_00F8_0000_0000_0000_0000_0000_0000_u128) {
            return f128.Zero;
        }
    } else if e < 0x3FFF - 114 {
        return f128.One + x;
    }

    u := x + ExpRedux;
    i0 := u.Bits.Low64().NarrowToUInt32() + Exp2TableSize \ 2;
    let ku := i0 \ Exp2TableSize * Exp2TableSize;
    let ki := ku.NarrowToInt32() \ Exp2TableSize;
    i0 %= Exp2TableSize;
    u -= ExpRedux;
    z := x - u;

    let t := Exp2Table[i0];
    z -= ExpEpsilon[i0];
	let r9 := (ExpP9 + z * ExpP10);
	let r8 := (ExpP8 + z * r9);
	let r7 := (ExpP7 + z * r8);
	let r6 := (ExpP6 + z * r7);
	let r5 := (ExpP5 + z * r6);
	let r4 := (ExpP4 + z * r5);
	let r3 := (ExpP3 + z * r4);
	let r2 := (ExpP2 + z * r3);
	let r1 := (ExpP1 + z * r2);
    let r := t + t * z * r1;

    return r.ScaleB(ki);
}

internal Exp10Impl: (x: f128) -> f128
{
    const Pow10: f128[_] == [
        f128.FromBits(0x3FCD_203A_F9EE_7561_59B2_1F3A_6E02_97EC_u128), // 1E-15
        f128.FromBits(0x3FD0_6849_B86A_12B9_B01E_A709_0983_3DE7_u128), // 1E-14
        f128.FromBits(0x3FD3_C25C_2684_9768_1C26_50CB_4BE4_0D61_u128), // 1E-13
        f128.FromBits(0x3FD7_1979_9812_DEA1_1197_F27F_0F6E_885D_u128), // 1E-12
        f128.FromBits(0x3FDA_5FD7_FE17_9649_55FD_EF1E_D34A_2A74_u128), // 1E-11
        f128.FromBits(0x3FDD_B7CD_FD9D_7BDB_AB7D_6AE6_881C_B511_u128), // 1E-10
        f128.FromBits(0x3FE1_12E0_BE82_6D69_4B2E_62D0_1511_F12A_u128), // 1E-09
        f128.FromBits(0x3FE4_5798_EE23_08C3_9DF9_FB84_1A56_6D75_u128), // 1E-08
        f128.FromBits(0x3FE7_AD7F_29AB_CAF4_8578_7A65_20EC_08D2_u128), // 1E-07
        f128.FromBits(0x3FEB_0C6F_7A0B_5ED8_D36B_4C7F_3493_8583_u128), // 1E-06
        f128.FromBits(0x3FEE_4F8B_588E_368F_0846_1F9F_01B8_66E4_u128), // 1E-05
        f128.FromBits(0x3FF1_A36E_2EB1_C432_CA57_A786_C226_809D_u128), // 1E-04
        f128.FromBits(0x3FF5_0624_DD2F_1A9F_BE76_C8B4_3958_1062_u128), // 1E-03
        f128.FromBits(0x3FF8_47AE_147A_E147_AE14_7AE1_47AE_147B_u128), // 1E-02
        f128.FromBits(0x3FFB_9999_9999_9999_9999_9999_9999_999A_u128), // 1E-01
        f128.FromBits(0x3FFF_0000_0000_0000_0000_0000_0000_0000_u128), // 1E00
        f128.FromBits(0x4002_4000_0000_0000_0000_0000_0000_0000_u128), // 1E01
        f128.FromBits(0x4005_9000_0000_0000_0000_0000_0000_0000_u128), // 1E02
        f128.FromBits(0x4008_F400_0000_0000_0000_0000_0000_0000_u128), // 1E03
        f128.FromBits(0x400C_3880_0000_0000_0000_0000_0000_0000_u128), // 1E04
        f128.FromBits(0x400F_86A0_0000_0000_0000_0000_0000_0000_u128), // 1E05
        f128.FromBits(0x4012_E848_0000_0000_0000_0000_0000_0000_u128), // 1E06
        f128.FromBits(0x4016_312D_0000_0000_0000_0000_0000_0000_u128), // 1E07
        f128.FromBits(0x4019_7D78_4000_0000_0000_0000_0000_0000_u128), // 1E08
        f128.FromBits(0x401C_DCD6_5000_0000_0000_0000_0000_0000_u128), // 1E09
        f128.FromBits(0x4020_2A05_F200_0000_0000_0000_0000_0000_u128), // 1E10
        f128.FromBits(0x4023_7487_6E80_0000_0000_0000_0000_0000_u128), // 1E11
        f128.FromBits(0x4026_D1A9_4A20_0000_0000_0000_0000_0000_u128), // 1E12
        f128.FromBits(0x402A_2309_CE54_0000_0000_0000_0000_0000_u128), // 1E13
        f128.FromBits(0x402D_6BCC_41E9_0000_0000_0000_0000_0000_u128), // 1E14
        f128.FromBits(0x4030_C6BF_5263_4000_0000_0000_0000_0000_u128)  // 1E15
    ];

    let e:i32 = Exponent(x);
    let sign := x.IsNegative;
    n, y: f128;

    // no fractional part
    if e >= 112 {
        n = x;
        if x.IsNaN {
            y = x;
        } else {
            y = sign ? f128.NegativeZero : f128.Zero;
        }
    }
    // no integral part
    else if e < 0 {
        n = sign ? f128.NegativeZero : f128.Zero;
        y = x;
    } else {
        let xAbs := x.Abs;
        let largeNum := RoundingEpsilon;
        mod := xAbs + largeNum - largeNum - xAbs;
        if mod == 0 {
            n = x;
            y = sign ? f128.NegativeZero : f128.Zero;
        } else if mod > 0 {
            mod--;
            n = x + mod;
            y = -mod;
        } else if sign {
            mod = -mod;
            n = x + mod;
            y = -mod;
        } else {
			n = x + mod;
            y = -mod;
		}
    }

    if BiasedExponent(n) < 0x3FFF + 4 {
        if y == 0 {
            return Pow10[n.NarrowToInt32() + 15];
        }
        y = (f128.FromBits(0x4000_A934_F097_9A37_15FC_9257_EDFE_9B5F_u128) * y).Exp2;
        return y * Pow10[n.NarrowToInt32() + 15];
    }

    return Pow10[16] ** x;
}

internal ExpM1Impl: (x: f128) -> f128
{
    const CP0 :== 2.943520915569954073888921213330863757240e8_f128;
	const CP1 :== -5.722847283900608941516165725053359168840e7_f128;
	const CP2 :== 8.944630806357575461578107295909719817253e6_f128;
	const CP3 :== -7.212432713558031519943281748462837065308e5_f128;
	const CP4 :== 4.578962475841642634225390068461943438441e4_f128;
	const CP5 :== -1.716772506388927649032068540558788106762e3_f128;
	const CP6 :== 4.401308817383362136048032038528753151144e1_f128;
	const CP7 :== -4.888737542888633647784737721812546636240e-1_f128;
	const Q0 :== 1.766112549341972444333352727998584753865e9_f128;
	const Q1 :== -7.848989743695296475743081255027098295771e8_f128;
	const Q2 :== 1.615869009634292424463780387327037251069e8_f128;
	const Q3 :== -2.019684072836541751428967854947019415698e7_f128;
	const Q4 :== 1.682912729190313538934190635536631941751e6_f128;
	const Q5 :== -9.615511549171441430850103489315371768998e4_f128;
	const Q6 :== 3.697714952261803935521187272204485251835e3_f128;
	const Q7 :== -8.802340681794263968892934703309274564037e1_f128;
	const CC1 :== 6.93145751953125e-1_f128;
	const CC2 :== 1.428606820309417232121458176568075500134e-6_f128;
	const minarg :== -7.9018778583833765273564461846232128760607e1_f128;
	const big :== 1e4932_f128;

	let bits := x.Bits;
	let sign := (bits & SignMask) != 0;
	let exp := ExtractBiasedExponentFromBits(bits);
	let sig := ExtractTrailingSignificandFromBits(bits);
	// x > 0 and exp >= 6
	if not sign and exp >= 0x4006 {
		return ExpImpl(x);
	}

	// -inf or nan
	if exp >= 0x7fff {
		// e^-inf -1 = -1
		if sig == 0 {
			return f128.MinusOne;
		}

		// NaN
		return f128.NaN;
	}

	// e^0 -1 = 0
	if exp == 0 and sig == 0 {
		return x;
	}

	// minimum value
	if x < minarg {
		return f128(4) / big - 1;
	}

	// underflow
	if x.Abs < 9.62964972193618e-35_f128 {
		return x;
	}

	xx := CC1 + CC2;
	px := (f128(0.5) + x / xx).Floor;
	let k := px.NarrowToInt32();
	x -= px * CC1;
	x -= px * CC2;

	x0 := CP7 * x + CP6;
	x0 = x0 * x + CP5;
	x0 = x0 * x + CP4;
	x0 = x0 * x + CP3;
	x0 = x0 * x + CP2;
	x0 = x0 * x + CP1;
	x0 = x0 * x + CP0;
	px = x0 * x;

	x0 = x + Q7;
	x0 = x0 * x + Q6;
	x0 = x0 * x + Q5;
	x0 = x0 * x + Q4;
	x0 = x0 * x + Q3;
	x0 = x0 * x + Q2;
	x0 = x0 * x + Q1;
	qx := x0 * x + Q0;

	xx = x * x;
	qx = x + (f128(0.5) * xx + xx * px / qx);
	px = f128.One.ScaleB(k);
	x = px * qx + (px - f128.One);
	return x;
}

private {
    const SignMask :== 0x8000_0000_0000_0000_0000_0000_0000_0000_u128;
    const SignShift :== 127i32;
    const ShiftedSignMask: u8 == u8(SignMask >> SignShift);

    const BiasedExponentMask :== 0x7FFF_0000_0000_0000_0000_0000_0000_0000_u128;
    const BiasedExponentShift :== 112i32;
    const ShiftedBiasedExponentMask: u16 == u16(BiasedExponentMask >> BiasedExponentShift);

    const TrailingSignificandMask :== 0x0000_FFFF_FFFF_FFFF_FFFF_FFFF_FFFF_FFFF_u128;

    const MinSign :== 0u8;
    const MaxSign :== 1u8;
    const MinBiasedExponent :== u16.MinValue;
    const MaxBiasedExponent :== 0x7FFFu16;
    const ExpBias :== 16383u16;
    const MinExponent :== -16382i16;
    const MaxExponent :== +16383i16;
    const MinTrailingSignificand :== u128.MinValue;
    const MaxTrailingSignificand :== 0x0000_FFFF_FFFF_FFFF_FFFF_FFFF_FFFF_FFFF_u128;

    const TrailingSignificandLength :== 112;
    const SignificandLength :== TrailingSignificandLength + 1;

    const RoundingEpsilon :== Builtin.BitCast<f128>(0x406F_0000_0000_0000_0000_0000_0000_0000_u128);

    BiasedExponent: (value: f128) -> u16 noexcept ==> ExtractBiasedExponentFromBits(value.Bits);
    Exponent: (value: f128) -> i16 noexcept ==> i16(BiasedExponent(value)) - ExpBias;
    Significand: (value: f128) -> u128 noexcept ==> TrailingSignificand(value) | (BiasedExponent(value) != 0 ? (1u128 << BiasedExponentShift) : 0u128);
    TrailingSignificand: (value: f128) -> u128 noexcept ==> ExtractTrailingSignificandFromBits(value.Bits);

    ExtractBiasedExponentFromBits: (bits: u128) -> u16 noexcept ==> u16((bits >> BiasedExponentShift) & ShiftedBiasedExponentMask);
    ExtractTrailingSignificandFromBits: (bits: u128) -> u128 noexcept ==> bits & TrailingSignificandMask;
}


