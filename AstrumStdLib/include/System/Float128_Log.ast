private LogConstantG: (index: i32) -> f32 ==> T[index].g;
private LogConstantFHi: (index: i32) -> f32 ==> T[index].fhi;
private LogConstantFLo: (index: i32) -> f128 ==> T[index].flo;
private LogConstantE: (index: i32) -> f32 ==> U[index].e;
private LogConstantH: (index: i32) -> f32 ==> U[index].h;

private const P2: f128 == f128.FromBits(0xBFFE_0000_0000_0000_0000_0000_0000_0000_u128);
private const P3: f128 == f128.FromBits(0x3FFD_5555_5555_5555_5555_5555_5555_4D42_u128);
private const P4: f128 == f128.FromBits(0xBFFC_FFFF_FFFF_FFFF_FFFF_FFFF_FFDA_B14E_u128);
private const P5: f128 == f128.FromBits(0x3FFC_9999_9999_9999_9999_999A_6D35_67F4_u128);
private const P6: f128 == f128.FromBits(0xBFFC_5555_5555_5555_5555_5672_67A5_8E13_u128);
private const P7: f128 == f128.FromBits(0x3FFC_2492_4924_9249_248E_D79A_0AE4_34DE_u128);
private const P8: f128 == f128.FromBits(0xBFFB_FFFF_FFFF_FFFF_FA13_E917_65E4_6140_u128);
private const P9: f128 == f128.FromBits(0x3FFB_C71C_71C7_1C7E_D54D_6D66_A8B2_C988_u128);
private const P10: f128 == f128.FromBits(0xBFFB_9999_9999_A0A9_1EA5_57FE_E717_E405_u128);
private const P11: f128 == f128.FromBits(0x3FFB_745D_1739_6211_107D_5489_11E4_3450_u128);
private const P12: f128 == f128.FromBits(0xBFFB_5555_5172_2C7A_2FC3_D1C0_7002_5776_u128);
private const P13: f128 == f128.FromBits(0x3FFB_3B19_8520_4A4A_E07C_9C4B_3F70_D6F0_u128);
private const P14: f128 == f128.FromBits(0xBFFB_2562_276C_DC5C_FF73_89B1_89F8_903B_u128);

private Sum2: (ref a: f128, ref b: f128) noexcept ==
{
    let w := a + b;
    b = a - w + b;
    a = w;
}

private Sum3: (ref a: f128, ref b: f128, c: f64) noexcept ==
{
    tmp: f128 = c;
    Sum2(&tmp, &a);
    b += a;
    a = tmp;
}

private inline PackBits: (sign: bool, exponent: u16, mantissa: u128) -> u128
    ==> ((sign ? 1u128 : 0u128) << SignShift) + ((u128(exponent) << BiasedExponentShift) & BiasedExponentMask) + mantissa;

// Natural logarithm implementation
private LogInternal: (x: f128) -> LD
{
    /* origin: FreeBSD /usr/src/lib/msun/ld128/s_logl.c */

    rp: LD;
    lx: u64;
    hx := BiasedExponent(x);
    k := -16383;
    
    if x.IsNegative or x.IsZero or x.IsNaN {
        if (u128(hx) | TrailingSignificand(x)) == 0 {
            rp.High = f128.NegativeInfinity;
            return rp;
        }

        rp.High = f128.NaN;
        return rp;
    }
    if x.IsInfinity {
        rp.High = x;
        return rp;
    }
    if x.IsSubnormal {
        x *= f128.FromBits(0x4070_0000_0000_0000_0000_0000_0000_0000_u128);
        k -= 113;
        lx = TrailingSignificand(x).High64();
        hx = BiasedExponent(x);
    } else {
        lx = TrailingSignificand(x).High64();
    }

    k += (hx | (x.IsNegative ? 1u16 << 15 : 0u16));
    let dk: f64 = k;
    x = f128.FromBits(PackBits(false, 0x3fffu16, TrailingSignificand(x)));

    const l2i := 49 - 7;
    let i := ((lx +% (1u64 << (l2i - 2))) >> (l2i - 1)).NarrowToInt32();
    let d := (x - LogConstantH(i)) * LogConstantG(i) + LogConstantE(i);
    let dd := d as f64;

    resultLo: f128 = d * d * d * (P3 +
        d * (P4 + d * (P5 + d * (P6 + d * (P7 + d * (P8 +
        dd * (P9 + dd * (P10 + dd * (P11 + dd * (P12 + dd * (P13 +
        dd * P14))))))))))) + (LogConstantFLo(i) + dk * LN2LO) + d * d * P2;
    resultHi: f128 = d;

    Sum3(&resultHi, &resultLo, LogConstantFHi(i) + dk * LN2HI);
    rp = { resultHi, resultLo, 1 };
    return rp;
}
