package System;

import Float128;

internal Log2Impl: (x: f128) -> f128 
{
    const InvLn2Hi: f128 == 1.4426950402557850e0;
    const InvLn2LoPHi :== f128.FromBits(0x3FFF_7154_7652_B82F_E24D_68D5_7C9B_F07B_u128);
    const InvLn2Lo :== f128.FromBits(0x3FE0_5C17_F0BB_BE87_FED0_691D_3E88_EB57_u128);

    r := LogInternal(x);
    if r.LowSet == 0 {
        return r.High;
    }

    let w := r.High + r.Low;
    r.Low = r.High - w + r.Low;
    r.High = w;

    let high: f128 = r.High as f32;
    let low: f128 = r.Low + (r.High - high);
    return InvLn2Hi * high + (InvLn2LoPHi * low + InvLn2Lo * high);
}

internal Log10Impl: (x: f128) -> f128
{
    const InvLn10Hi: f128 == 4.3429448176175356e-1;
    const InvLn10LoPHi :== f128.FromBits(0x3FFD_BCB7_B152_6E50_E36B_E631_DFF2_801F_u128);
    const InvLn10Lo :== f128.FromBits(0x3FDE_3728_7195_355B_AAAF_AD33_DC32_3EE3_u128);

    r := LogInternal(x);
    if r.LowSet == 0 {
        return r.High;
    }

    let w := r.High + r.Low;
    r.Low = r.High - w + r.Low;
    r.High = w;

    let high: f128 = r.High as f32;
    let low: f128 = r.Low + (r.High - high);
    return InvLn10Hi * high + (InvLn10LoPHi * low + InvLn10Lo * high);
}

internal LnImpl: (x: f128) -> f128
{
    let r := LogInternal(x);
    return r.LowSet == 0 ? r.High : r.High + r.Low;
}

internal LnP1Impl: (x: f128) -> f128
{
    /* origin: FreeBSD /usr/src/lib/msun/ld128/s_logl.c */

    hx := (BiasedExponent(x) | (x.IsNegative ? 1u16 << 15 : 0u16)).NarrowToInt16();

    fHi, fLo: f128;
    // x < 1
    if hx < 0x3FFF {
        let ax := hx & 0x7FFF;
        // x <= -1
        if ax >= 0x3FFF {
            // -inf
            if ax == 0x3FFF and TrailingSignificand(x) == 0 {
                return f128.NegativeInfinity;
            }

            // negative or -nan
            return f128.NaN;
        }

        // |x| < 2^(-113)
        if ax <= 0x3F8D and x.ToInt64() == 0 {
            return x;
        }

        fHi = 1;
        fLo = x;
    } else if hx >= 0x7FFF {
        // inf or nan
        return x;
    } else if hx < 0x40E1 {
        // 1 <= x < 2^226
        fHi = x;
        fLo = 1;
    } else {
        // x >= 2^226
        fHi = x;
        fLo = 0;
    }

    x = fHi + fLo;
    fLo = fHi - x + fLo;
    hx = BiasedExponent(x).NarrowToInt16();

    let lx := TrailingSignificand(x).High64();
    let k := -16383 + (hx | (x.IsNegative ? 1u16 << 15 : 0u16));
    let dk: f64 = k;

    x = f128.FromBits(PackBits(false, 0x3fffu16, TrailingSignificand(x)));
    let twopmk := f128.FromBits(u128(u64(0x7ffe - hx) << 48, 0u));
    fLo *= twopmk;

    const l2i := 49 - 7;
    let i := ((lx +% (1u64 << (l2i - 2))) >> (l2i - 1)).NarrowToInt32();
    
    dHi := (x - LogConstantH(i)) * LogConstantG(i) + LogConstantE(i);
    dLo := (fLo * LogConstantG(i)) as f64;

    let d := dHi + dLo;
    let dd := d as f64;
    dLo = (dHi - d + dLo) as f64;
    dHi = d;

    resultLo: f128 = d * d * d * (P3 +
        d * (P4 + d * (P5 + d * (P6 + d * (P7 + d * (P8 +
        dd * (P9 + dd * (P10 + dd * (P11 + dd * (P12 + dd * (P13 +
        dd * P14))))))))))) + (LogConstantFLo(i) + dk * LN2LO + dLo) + d * d * P2;
    resultHi: f128 = dHi;

    Sum3(&resultHi, &resultLo, LogConstantFHi(i) + dk * LN2HI);
    return resultHi + resultLo;
}

private {
    const SignMask :== 0x8000_0000_0000_0000_0000_0000_0000_0000_u128;
    const SignShift :== 127i32;
    const ShiftedSignMask: u8 == u8(SignMask >> SignShift);

    const BiasedExponentMask :== 0x7FFF_0000_0000_0000_0000_0000_0000_0000_u128;
    const BiasedExponentShift :== 112i32;
    const ShiftedBiasedExponentMask: u16 == u16(BiasedExponentMask >> BiasedExponentShift);

    const TrailingSignificandMask :== 0x0000_FFFF_FFFF_FFFF_FFFF_FFFF_FFFF_FFFF_u128;

    const MinSign :== 0u8;
    const MaxSign :== 1u8;
    const MinBiasedExponent :== u16.MinValue;
    const MaxBiasedExponent :== 0x7FFFu16;
    const ExpBias :== 16383u16;
    const MinExponent :== -16382i16;
    const MaxExponent :== +16383i16;
    const MinTrailingSignificand :== u128.MinValue;
    const MaxTrailingSignificand :== 0x0000_FFFF_FFFF_FFFF_FFFF_FFFF_FFFF_FFFF_u128;

    const TrailingSignificandLength :== 112;
    const SignificandLength :== TrailingSignificandLength + 1;

    const RoundingEpsilon :== Builtin.BitCast<f128>(0x406F_0000_0000_0000_0000_0000_0000_0000_u128);

    BiasedExponent: (value: f128) -> u16 noexcept ==> ExtractBiasedExponentFromBits(value.Bits);
    Exponent: (value: f128) -> i16 noexcept ==> i16(BiasedExponent(value) - ExpBias);
    Significand: (value: f128) -> u128 noexcept ==> TrailingSignificand(value) | (BiasedExponent(value) != 0 ? (1u128 << BiasedExponentShift) : 0u128);
    TrailingSignificand: (value: f128) -> u128 noexcept ==> ExtractTrailingSignificandFromBits(value.Bits);

    ExtractBiasedExponentFromBits: (bits: u128) -> u16 noexcept ==> u16((bits >> BiasedExponentShift) & ShiftedBiasedExponentMask);
    ExtractTrailingSignificandFromBits: (bits: u128) -> u128 noexcept ==> bits & TrailingSignificandMask;
}

