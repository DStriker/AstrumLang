package System;

public type Int8 = i8;

public extension i8 {
    //operator +*/: (other: i8) -> i8 ==> this + other;

}


test "Int8"
{
    static assert(sizeof(i8) == 1, "i8 should be 1 byte");

    a: i8 = 5;
    b:= 10i8;

    // add with various types
    assert a + 10i8 == 15;
    assert a + 10u8 == 15;
    assert a + 10i16 == 15;
    assert a + 10u16 == 15;
    assert a + 10i32 == 15;
    assert a + 10u32 == 15;
    assert a + 10i64 == 15;
    assert a + 10u64 == 15;
    assert a + 10i128 == 15;
    assert a + 10u128 == 15;

    // basic arithmetic
    assert a - 12 == -7;
    assert a * 2 == 10;
    assert a / 2 == 2;
    assert a % 2 == 1;
    assert (a & 1) == 1;
    assert (a | 1) == 5;
    assert (a ^ 1) == 4;
    assert a << 1 == 10;
    assert a >> 1 == 2;

    // assignment
    a = 5;
    /*a++;
    a--;
    a += 5;
    a -= 5;
    a *= 2;
    a /= 2;
    a %= 1;
    a &= 1;
    a |= 1;
    a ^= 1;
    a <<= 1;
    a >>= 1;*/

    // comparisons
    assert a == 5;
    assert a != 6;
    assert a < 6;
    assert a <= 5;
    assert a > 4;
    assert a >= 5;
	assert i8.Min == -128;
}